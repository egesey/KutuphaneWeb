@model KutuphaneWeb.Models.Book

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Delete Book</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body {
            background-color: #121212;
            color: #ddd;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 30px;
        }
        .container {
            max-width: 500px;
            background-color: #1e1e1e;
            padding: 30px;
            border-radius: 12px;
            box-shadow: 0 0 25px rgba(0,0,0,0.8);
        }
        h2 {
            color: #d32f2f; /* Koyu kırmızı ton */
            font-weight: 700;
            margin-bottom: 25px;
            text-align: center;
        }
        p.text-center {
            color: #ccc;
            margin-bottom: 30px;
            font-size: 1.1rem;
            font-weight: 600;
        }
        table {
            width: 100%;
            margin-bottom: 30px;
            color: #ccc;
            border-collapse: separate;
            border-spacing: 0 12px;
        }
        td:first-child {
            font-weight: 600;
            color: #81a1c1;
            width: 35%;
            padding-left: 6px;
        }
        td:last-child {
            color: #d8dee9;
            padding-left: 10px;
        }
        button.btn-danger {
            width: 100%;
            padding: 12px;
            background-color: #d32f2f;
            border: none;
            font-weight: 700;
            font-size: 1.15em;
            border-radius: 8px;
            transition: background-color 0.3s ease;
        }
        button.btn-danger:hover {
            background-color: #d32f2f;
        }
        a.btn-secondary {
            display: block;
            margin-top: 15px;
            text-align: center;
            color: #1565c0;
            font-weight: 600;
            text-decoration: none;
            border: 2px solid #1565c0;
            padding: 10px 0;
            border-radius: 8px;
            transition: background-color 0.3s ease, color 0.3s ease;
            background-color: #1e1e1e;
        }
       
        a.btn-secondary:hover {
            background-color: #81a1c1;
            color: #121212;
            text-decoration: none;
        }
    </style>
</head>
<body>
    <div class="container">
        <h2> Delete Book</h2>
        <p class="text-center">Are you sure you want to delete this book?</p>
        <table>
            <tr>
                <td>Name:</td>
                <td>@Model.Name</td>
            </tr>
            <tr>
                <td>Author:</td>
                <td>@Model.Author</td>
            </tr>
            <tr>
                <td>Year:</td>
                <td>@Model.Year</td>
            </tr>
            <tr>
                <td>Price:</td>
                <td>@Model.Price.ToString("0.00") ₺</td>
            </tr>
        </table>
        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="BId" />
            <button type="submit" class="btn btn-danger">Delete</button>
        </form>
        <a href="/Book/Index" class="btn btn-secondary">Cancel</a>
    </div>
</body>
</html>
