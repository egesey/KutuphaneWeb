@model KutuphaneWeb.Models.Book

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <title>Edit Book</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body {
            background-color: #121212;
            color: #ddd;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 30px;
        }
        .container {
            background-color: #1e1e1e;
            padding: 30px 40px;
            border-radius: 12px;
            box-shadow: 0 0 25px rgba(0,0,0,0.8);
            width: 100%;
            max-width: 450px;
        }
        h2 {
            color: #283593;
            font-weight: 700;
            margin-bottom: 30px;
            text-align: center;
        }
        label {
            color: #88c0d0;
            font-weight: 600;
        }
        input.form-control {
            background-color: #2e3440;
            border: 1.5px solid #434c5e;
            color: #d8dee9;
            border-radius: 8px;
            transition: border-color 0.3s ease;
        }
        input.form-control:focus {
            background-color: #3b4252;
            border-color: #81a1c1;
            color: #eceff4;
            box-shadow: 0 0 8px #81a1c1;
            outline: none;
        }
        .btn-primary {
            background-color: #388e3c;
            border: none;
            width: 100%;
            font-weight: 600;
            padding: 10px 0;
            border-radius: 8px;
            transition: background-color 0.3s ease;
        }
        .btn-primary:hover {
            background-color: #2e7031;
        }
        a.btn-back {
            display: inline-block;
            margin-top: 20px;
            color: #1565c0;
            font-weight: 600;
            text-decoration: none;
            border: 2px solid #1565c0;
            padding: 8px 22px;
            border-radius: 8px;
            transition: background-color 0.3s ease, color 0.3s ease;
            text-align: center;
            width: 100%;
        }
        a.btn-back:hover {
            background-color: #81a1c1;
            color: #121212;
            text-decoration: none;
        }
    </style>
</head>
<body>
    <div class="container">
        <h2>Edit Book</h2>
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="BId" value="@Model.BId" />

            <div class="mb-3">
                <label name="Name" class="form-label"></label>
                <input name="Name" class="form-control" placeholder="Book Name" />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label name="Author" class="form-label"></label>
                <input name="Author" class="form-control" placeholder="Author Name" />
                <span asp-validation-for="Author" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label name="Year" class="form-label"></label>
                <input name="Year" class="form-control" placeholder="Publication Year" />
                <!-- burda asp-for="Year" kullanırsan bunda çalışmıyor name kalıbı kullanman gerekiyor name="Year" şeklinde olmalı
            tüm edit book butonunun çalışmama nedeni buymuş -->
                <span asp-validation-for="Year" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label name="Price" class="form-label"></label>
                <input name="Price" class="form-control" placeholder="Price in ₺" />
                <span asp-validation-for="Price" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn btn-primary">Update Book</button>
            <a href="/Book/Index" class="btn-back">Back to List</a>
        </form>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <partial name="_ValidationScriptsPartial" />
</body>
</html>