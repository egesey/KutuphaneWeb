@model IEnumerable<KutuphaneWeb.Models.Rating>

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title> Book Ratings</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body {
            background-color: #121212;
            color: #ddd;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 30px;
        }
        .container {
            max-width: 700px;
            background-color: #1e1e1e;
            border-radius: 12px;
            box-shadow: 0 0 25px rgba(0, 0, 0, 0.8);
            padding: 30px 40px;
        }
        h1 {
            color: #283593;
            font-weight: 700;
            margin-bottom: 35px;
            text-align: center;
        }
        a.btn-back {
            display: inline-block;
            margin-bottom: 30px;
            color: #1565c0;
            font-weight: 600;
            text-decoration: none;
            border: 2px solid #1565c0;
            padding: 8px 22px;
            border-radius: 8px;
            transition: background-color 0.3s ease, color 0.3s ease;
        }
        a.btn-back:hover {
            background-color: #81a1c1;
            color: #121212;
            text-decoration: none;
        }
        table {
            width: 100%;
            color: #ddd;
            font-size: 1rem;
            border-collapse: separate;
            border-spacing: 0 10px;
        }
        thead {
            background: linear-gradient(90deg, #283593, #3949ab);
            color: #ffffff;
            font-weight: 600;
            border-radius: 12px;
        }
        thead tr th {
            padding: 12px 15px;
        }
        tbody tr {
            background-color: #292929;
            transition: background-color 0.3s ease;
            border-radius: 10px;
            box-shadow: 0 2px 6px rgba(0,0,0,0.6);
        }
        tbody tr:hover {
            background-color: #3949ab;
            color: #ffffff;
        }
        tbody tr td {
            padding: 14px 15px;
        }
        tbody tr td:first-child {
            font-weight: 600;
            color: #88c0d0;
            text-align: center;
            width: 5%;
        }
    </style>
</head>
<body>
    <div class="container">
        <h1> Book Ratings</h1>
        <a href="/Book/Index" class="btn-back">← Back to List</a>

        <table>
            <thead>
                <tr>
                    <th>#</th>
                    <th>RaId</th>
                    <th>Name</th>
                    <th>Ratings</th>
                </tr>
            </thead>
            <tbody>
                @{
                    int rowNumber = 1;
                }
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@rowNumber</td>
                        <td>@item.RaId</td>
                        <td>@item.Name</td>
                        <td>@item.Ratings</td>
                    </tr>
                    rowNumber++;
                }
            </tbody>
        </table>
    </div>
</body>
</html>
