@model KutuphaneWeb.Models.Book
@{
    ViewData["Title"] = "Add New Book";
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body {
            background-color: #121212;
            color: #e0e0e0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 30px;
        }

        .container {
            max-width: 480px;
            background-color: #1e1e1e;
            padding: 30px 35px;
            border-radius: 12px;
            box-shadow: 0 0 25px rgba(0,0,0,0.8);
        }

        h1 {
            color: #283593;
            font-weight: 700;
            margin-bottom: 25px;
            text-align: center;
        }

        label {
            color: #88c0d0;
            font-weight: 600;
        }

        input.form-control {
            background-color: #2e3440;
            border: 1.5px solid #434c5e;
            color: #d8dee9;
            border-radius: 8px;
            transition: border-color 0.3s ease;
        }

        input.form-control:focus {
            background-color: #3b4252;
            border-color: #81a1c1;
            color: #eceff4;
            box-shadow: 0 0 8px #81a1c1;
            outline: none;
        }

        .btn-primary {
            background-color: #388e3c;
            border: none;
            font-weight: 600;
            width: 100%;
            padding: 12px 0;
            border-radius: 8px;
            transition: background-color 0.3s ease;
        }

        .btn-primary:hover {
            background-color: #2e7031;
        }

        a.btn-back {
            display: block;
            margin-top: 20px;
            text-align: center;
            color: #1565c0;
            font-weight: 600;
            text-decoration: none;
            border: 2px solid #1565c0;
            padding: 10px 0;
            border-radius: 8px;
            transition: background-color 0.3s ease, color 0.3s ease;
        }

        a.btn-back:hover {
            background-color: #81a1c1;
            color: #121212;
            text-decoration: none;
        }

        .text-danger {
            color: #bf616a !important;
        }
    </style>
</head>
<body>
    <div class="container">
        <h1>Add New Book</h1>
        <form action="/Book/Create" method="post">
            @Html.AntiForgeryToken()

            <div class="mb-3">
                <label for="Name" class="form-label">Book Name</label>
                <input type="text" name="Name" class="form-control" placeholder="Book Name" />
            </div>

            <div class="mb-3">
                <label for="Author" class="form-label">Author Name</label>
                <input type="text" name="Author" class="form-control" placeholder="Author Name" />
            </div>

            <div class="mb-3">
                <label for="Year" class="form-label">Year</label>
                <input type="number" name="Year" class="form-control" placeholder="Year" />
            </div>                   <!-- burda asp-for="Year" kullanırsan bunda çalışmıyor name kalıbı kullanman gerekiyor name="Year" şeklinde olmalı
            tüm add book butonunun çalışmama nedeni buymuş -->

            <div class="mb-3">  
                <label for="Price" class="form-label">₺ Price</label>
                <input type="number" name="Price" step="1.00" class="form-control" placeholder="₺ Price" />
            </div>                 

            <button type="submit" class="btn btn-primary">Add Book</button>
        </form>
        <a href="/Book/Index" class="btn-back">← Back to List</a>
    </div>
</body>
</html>
