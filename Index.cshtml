@model IEnumerable<KutuphaneWeb.Models.Book>

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>LibaryWeb</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body {
            background-color: #121212; /* Çok koyu siyah-gri arka plan */
            color: #e0e0e0; /* Açık gri yazı */
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }
        .header-title {
            color: #283593; /* Açık mavi ton, okunaklı ve hoş */
            font-weight: 700;
            letter-spacing: 1.2px;
        }
        .btn-success {
            background-color: #388e3c;
            border: none;
        }
        .btn-success:hover {
            background-color: #2e7031;
        }
        .btn-info {
            background-color: #1565c0;
            border: none;
        }
        .btn-info:hover {
            background-color: #0d3c75;
        }
         .btn-primary {
            background-color: #1565c0;
            border: none;
        }
        .btn-primary:hover {
            background-color: #0d3c75;
        }
        .btn-danger {
            background-color: #d32f2f;
            border: none;
        }
        .btn-danger:hover {
            background-color: #9a2424;
        }
        table {
            border-collapse: separate !important;
            border-spacing: 0 10px;
            width: 100%;
            background-color: #1e1e1e;
            border-radius: 10px;
            box-shadow: 0 0 15px rgba(0, 0, 0, 0.7);
            color: #e0e0e0;
        }
        thead tr {
            background: linear-gradient(90deg, #283593, #3949ab);
            color: #ffffff;
            font-weight: 600;
            border-radius: 10px;
        }
        tbody tr { 
            background-color: #292929;
            border-radius: 8px;
            transition: background-color 0.3s ease;
        }
        tbody tr:hover {
            background-color: #3949ab;
            color: #ffffff;
        }
        tbody tr td {
            padding: 12px 15px;
        }
        .container {
            max-width: 1100px;
            margin-top: 50px;
        }
         tbody tr td:first-child {
            font-weight: 600;
            color: #88c0d0;
            text-align: center;
            width: 5%;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="header-title"> LibaryWeb</h2>
            <div>
                <a href="/Book/Create" class="btn btn-success me-2">➕ Add New Book</a>
                <a href="/Book/RatingBook" class="btn btn-primary me-2"> Book Ratings</a>
                <a href="/Book/RBook" class="btn btn-primary"> Readen Books</a>
            </div>
        </div>

        <table class="text-center align-middle">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Book ID</th>
                    <th>Name</th>
                    <th>Author</th>
                    <th>Year</th>
                    <th>Price</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @{
                    int rowNumber = 1;
                }
                @foreach (var book in Model)
                {
                    <tr>
                        <td>@rowNumber</td>
                        <td>@book.BId</td>
                        <td>@book.Name</td>
                        <td>@book.Author</td>
                        <td>@book.Year</td>
                        <td>@book.Price.ToString("0.00") ₺</td>
                        <td>
                            <a href="/Book/Edit/@book.BId" class="btn btn-sm btn-primary">Edit</a>
                            <a href="/Book/Delete/@book.BId" class="btn btn-sm btn-danger ms-1">Delete</a>
                        </td>
                    </tr>
                    rowNumber++;
                }
            </tbody>
        </table>
    </div>
</body>
</html>
